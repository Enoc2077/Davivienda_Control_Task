@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<div class="sidebar-modern">

    @* HEADER: Perfil del Usuario *@
    <SidebarDavivienda Tipo="Header" />

    @* NAVEGACIÓN PRINCIPAL *@
    <div class="sidebar-navigation-area">
        <nav class="navigation-menu-modern">

            @* Home - Estilo simple como submenú *@
            <div class="nav-sub-container">
                <NavLink class="submenu-button-modern" href="home" Match="NavLinkMatch.All">
                    <i class="bi bi-house-door"></i>
                    <span>Home</span>
                </NavLink>
            </div>

            @* Asignaciones - Estilo simple como submenú *@
            <div class="nav-sub-container">
                <NavLink class="submenu-button-modern" href="Asignaciones">
                    <i class="bi bi-clipboard-check"></i>
                    <span>Asignaciones</span>
                </NavLink>
            </div>

            @* Menú de Administración - Solo para rol "Enoc" *@
            <AuthorizeView Roles="Enoc">
                <Authorized>
                    <SidebarDavivienda Tipo="MenuAdmin" />
                </Authorized>
            </AuthorizeView>

        </nav>
    </div>

    @* FOOTER: Cerrar Sesión *@
    <SidebarDavivienda Tipo="Footer" />

</div>