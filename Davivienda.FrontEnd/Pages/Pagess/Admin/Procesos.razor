@using Davivienda.Models.Modelos
@using Davivienda.GraphQL.SDK
@using Davivienda.Component.Componentes
@inherits Davivienda.FrontEnd.Pages.Pagess.Admin.Proceso

<div class="proc-fullscreen">

    @* ── TOPBAR ── *@
    <div class="proc-topbar">

        @* IZQUIERDA: título + búsqueda + historial *@
        <div class="proc-topbar-left">
            <div class="proc-titulo-grupo">
                <h1 class="proc-proyecto-title">@ProyectoNombre</h1>
                <span class="proc-proyecto-sub">Gestión detallada de procesos</span>
            </div>

            <div class="proc-search-pill">
                <i class="fas fa-search"></i>
                <input type="text"
                       placeholder="Buscar procesos..."
                       class="proc-search-input"
                       @oninput="OnSearchProcesoChanged" />
            </div>

            <button class="btn-proc-historial" @onclick="AbrirBitacoraProceso">
                <i class="bi bi-clock-history"></i> Historial
            </button>
        </div>

        @* DERECHA: solo flecha volver *@
        <div class="proc-topbar-right">
            <button class="btn-proc-volver" @onclick="CerrarModal" title="Volver a Proyectos">
                <i class="fas fa-arrow-left"> X </i>
            </button>
        </div>
    </div>

    @* ── DIVIDER ── *@
    <div class="proc-topbar-divider"></div>

    @* ── CONTENIDO 3 COLUMNAS ── *@
    <div class="proc-columns">

        @* ─── COL 1: LISTA DE PROCESOS ─── *@
        <div class="proc-col proc-col-lista">
            <div class="proc-col-header">
                <h3 class="proc-col-title">Listado de Procesos</h3>
                <button class="btn-proc-nuevo" @onclick="PrepararNuevoProceso">
                    <i class="fas fa-plus"></i> Nuevo
                </button>
            </div>
            <div class="proc-col-divider red"></div>

            <div class="proc-list-scroll">
                @if (!ProcesosFiltradosEnModal.Any())
                {
                    <div class="proc-empty">
                        <i class="bi bi-inbox"></i>
                        <p>Sin procesos</p>
                    </div>
                }

                @foreach (var proc in ProcesosFiltradosEnModal)
                {
                    <div class="proc-item @(ProcesoSeleccionado?.PROC_ID == proc.PROC_ID ? "proc-item-active" : "")"
                         @onclick="() => CargarTareasDelProceso(proc)">
                        <div class="proc-item-body">
                            <span class="proc-item-name">@proc.PROC_NOM</span>
                            <span class="proc-item-freq">@proc.PROC_FRE?.ToUpper()</span>
                        </div>
                        <div class="proc-item-actions">
                            <button class="btn-proc-delete"
                                    title="Eliminar proceso"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => ConfirmarEliminar(proc)">
                                <i class="bi bi-trash3"></i>
                            </button>
                            <i class="fas fa-chevron-right proc-item-arrow"></i>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* DIVISOR VERTICAL *@
        <div class="proc-vertical-divider"></div>

        @* ─── COL 2: CONFIGURACIÓN ─── *@
        <div class="proc-col proc-col-config">
            <div class="proc-col-header">
                <h3 class="proc-col-title">Configuración</h3>
                <button class="btn-proc-guardar" @onclick="GuardarCambiosProceso">
                    <i class="fas fa-check-circle"></i> Guardar
                </button>
            </div>
            <div class="proc-col-divider blue"></div>

            @if (ProcesoSeleccionado != null)
            {
                <div class="proc-form">

                    <div class="proc-form-group">
                        <label class="proc-label">NOMBRE DEL PROCESO</label>
                        <input type="text"
                               class="proc-input"
                               @bind="ProcesoSeleccionado.PROC_NOM"
                               placeholder="Nombre del proceso..." />
                    </div>

                    <div class="proc-form-row">
                        <div class="proc-form-group proc-form-group-flex">
                            <label class="proc-label">FRECUENCIA</label>
                            <select class="proc-select" @bind="ProcesoSeleccionado.PROC_FRE">
                                <option value="Diario">Diario</option>
                                <option value="Semanal">Semanal</option>
                                <option value="Mensual">Mensual</option>
                            </select>
                        </div>

                        <div class="proc-form-group">
                            <label class="proc-label">ESTADO</label>
                            <div class="proc-estado-toggle @(ProcesoSeleccionado.PROC_EST == true ? "estado-activo" : "estado-inactivo")"
                                 @onclick="() => ProcesoSeleccionado.PROC_EST = !(ProcesoSeleccionado.PROC_EST ?? false)">
                                <i class="@(ProcesoSeleccionado.PROC_EST == true ? "bi bi-check-circle-fill" : "bi bi-x-circle-fill")"></i>
                                @(ProcesoSeleccionado.PROC_EST == true ? "ACTIVO" : "INACTIVO")
                            </div>
                        </div>
                    </div>

                    <div class="proc-form-group proc-form-yoopta">
                        <label class="proc-label">DESCRIPCIÓN</label>
                        <div class="proc-yoopta-wrapper">
                            <Yoopta Contenido="@ProcesoSeleccionado.PROC_DES"
                                    ContenidoChanged="@OnDescripcionChanged" />
                        </div>
                    </div>

                </div>
            }
            else
            {
                <div class="proc-empty">
                    <i class="bi bi-arrow-left-circle"></i>
                    <p>Selecciona un proceso o crea uno nuevo</p>
                </div>
            }
        </div>

        @* DIVISOR VERTICAL *@
        <div class="proc-vertical-divider"></div>

        @* ─── COL 3: TAREAS ─── *@
        <div class="proc-col proc-col-tareas">
            <div class="proc-col-header">
                <h3 class="proc-col-title">Tareas</h3>
                @if (ProcesoSeleccionado?.PROC_ID != Guid.Empty && ProcesoSeleccionado != null)
                {
                    <button class="btn-proc-nueva-tarea" @onclick="AbrirCrearTarea">
                        <i class="fas fa-plus-circle"></i> Nueva
                    </button>
                }
            </div>
            <div class="proc-col-divider green"></div>

            <div class="proc-list-scroll">
                @if (TareasDelProceso != null && TareasDelProceso.Any())
                {
                    @foreach (var tar in TareasDelProceso)
                    {
                        <div class="tarea-item" @onclick="() => AbrirEditarTarea(tar)">
                            <div class="tarea-item-bar @(tar.TAR_EST == "Completado" ? "bar-green" : tar.TAR_EST == "En Progreso" ? "bar-blue" : "bar-orange")"></div>
                            <div class="tarea-item-body">
                                <span class="tarea-item-name">@tar.TAR_NOM</span>
                                <span class="tarea-item-est">@tar.TAR_EST?.ToUpper()</span>
                            </div>
                            <i class="fas fa-pencil-alt tarea-item-icon"></i>
                        </div>
                    }
                }
                else
                {
                    <div class="proc-empty">
                        <i class="bi bi-list-check"></i>
                        <p>Sin tareas en este proceso</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* ── CONFIRM ELIMINAR ── *@
@if (MostrarConfirmEliminar && ProcesoAEliminar != null)
{
    <div class="proc-confirm-overlay" @onclick="CancelarEliminar">
        <div class="proc-confirm-card" @onclick:stopPropagation="true">
            <div class="proc-confirm-icon">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <h3 class="proc-confirm-title">¿Eliminar proceso?</h3>
            <p class="proc-confirm-msg">
                Estás a punto de eliminar <strong>@ProcesoAEliminar.PROC_NOM</strong>.<br />
                Esta acción no se puede deshacer.
            </p>
            <div class="proc-confirm-btns">
                <button class="btn-confirm-cancel" @onclick="CancelarEliminar">Cancelar</button>
                <button class="btn-confirm-ok" @onclick="EjecutarEliminar">
                    <i class="bi bi-trash3"></i> Sí, eliminar
                </button>
            </div>
        </div>
    </div>
}

@* ── MODALES SECUNDARIOS ── *@
@if (MostrarModalTarea)
{
    <div class="modal-overlay-secondary">
        <Davivienda.Component.Componentes.EditarTarea Tarea="TareaSeleccionada" OnClose="CerrarModalTarea" />
    </div>
}
@if (MostrarModalCrearTarea)
{
    <div class="modal-overlay-secondary">
        <Davivienda.Component.Componentes.CrearTarea ProcId="ProcesoSeleccionado!.PROC_ID" OnClose="CerrarModalCrearTarea" />
    </div>
}
@if (MostrarBitacoraProceso)
{
    <Davivienda.Component.Componentes.BitacoraProceso OnClose="CerrarBitacoraProceso" ProyectoId="@ProyectoId" />
}
