@namespace Davivienda.Component.Componentes
@inherits Microsoft.AspNetCore.Components.ComponentBase
@using Davivienda.Models.Modelos

<div class="modal-fixed-backdrop">
    <div class="master-modal-container" @onclick:stopPropagation>
        <div class="dav-modal-art-bg">
            <button type="button" class="btn-close-modal" @onclick="Regresar">
                <i class="bi bi-x-lg"></i>
            </button>

            <div class="bg-blob blob-red-top"></div>
            <div class="bg-blob blob-red-bottom"></div>

            <div class="illustration-scene">
                <div class="device-monitor">
                    <div class="device-screen"><div class="screen-ui-lines"></div></div>
                    <div class="device-stand"></div>
                </div>
                <div class="vector-person person-standing"></div>
                <div class="vector-person person-climbing"></div>
                <div class="vector-person person-sitting"></div>
                <div class="floating-element element-1"></div>
                <div class="floating-element element-2"></div>
            </div>

            <div class="content-sectors-container">

                @* LISTADO *@
                <div class="sector-white-card sector-listado">
                    <div class="sector-label">Historial de Proyectos</div>
                    <div class="sector-banner-header">
                        <div class="banner-waves"></div>
                        <div class="banner-content">
                            <div class="banner-icon">
                                <i class="bi bi-archive-fill"></i> Bitácora de Proyectos Finalizados
                            </div>
                        </div>
                    </div>

                    <div class="solution-main-viewport">
                        @if (ProyectosFiltrados.Any())
                        {
                            @foreach (var proyecto in ProyectosFiltrados)
                            {
                                <div class="solution-item-card" @onclick="() => AbrirDetalleProyecto(proyecto)">
                                    <div class="sol-card-info">
                                        <span class="sol-name">@proyecto.PRO_NOM</span>
                                        <div class="tarea-metadata">
                                            <span class="metadata-item">
                                                <i class="bi bi-briefcase"></i> @ObtenerNombreArea(proyecto.ARE_ID)
                                            </span>
                                            <span class="metadata-item">
                                                <i class="bi bi-calendar-check"></i> @proyecto.PRO_FEC_INI.ToString("dd MMM yyyy")
                                            </span>
                                        </div>
                                    </div>
                                    <div class="sol-card-metrics">
                                        <div class="metric-badge status-finalizado">FINALIZADO</div>
                                        <div class="metric-badge effectiveness">@ObtenerCantidadProcesos(proyecto.PRO_ID) Procesos</div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-results-msg">
                                <i class="bi bi-inbox"></i>
                                <p>No hay proyectos finalizados en el historial.</p>
                            </div>
                        }
                    </div>
                </div>

                @* FILTROS — mismo componente que las demás bitácoras *@
                <div class="sector-white-card sector-filtros">
                    <div class="sector-label verde">Filtros Inteligentes</div>
                    <div class="dynamic-filter-zone">
                        <Filtros Areas="AreasList"
                                 Proyectos="ProyectosParaFiltro"
                                 Procesos="new()"
                                 Tareas="new()"
                                 Prioridades="new()"
                                 OnFiltrosChanged="ManejarCambioFiltros" />
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

@* ── MODAL DETALLE PROYECTO — hero + info + editar ── *@
@if (ProyectoSeleccionado != null && !MostrarEditar)
{
    <div class="modal-detalle-overlay" @onclick="CerrarDetalle">
        <div class="modal-detalle-card" @onclick:stopPropagation>

            <div class="modal-detalle-header">
                <div class="header-icon">
                    <i class="bi bi-archive-fill"></i>
                </div>
                <h3 class="modal-detalle-title">Detalle del Proyecto</h3>
                <button class="btn-cerrar-detalle" @onclick="CerrarDetalle">×</button>
            </div>

            <div class="modal-detalle-body">

                @* COLUMNA IZQUIERDA *@
                <div class="detalle-columna-info">

                    @* NOMBRE HERO *@
                    <div class="proyecto-nombre-hero">
                        <div class="proyecto-nombre-icon">
                            <i class="bi bi-folder2-open"></i>
                        </div>
                        <div class="proyecto-nombre-texto">
                            <span class="proyecto-nombre-label">NOMBRE DEL PROYECTO</span>
                            <h2 class="proyecto-nombre-titulo">@ProyectoSeleccionado.PRO_NOM</h2>
                        </div>
                    </div>

                    @* BADGE ESTADO *@
                    <div class="proyecto-badges-row">
                        <div class="proyecto-badge-item">
                            <span class="proyecto-badge-label">ESTADO</span>
                            <span class="badge-finalizado">
                                <i class="bi bi-archive"></i> @ProyectoSeleccionado.PRO_EST
                            </span>
                        </div>
                        <div class="proyecto-badge-item">
                            <span class="proyecto-badge-label">ÁREA</span>
                            <span class="badge-area">
                                <i class="bi bi-briefcase"></i> @ObtenerNombreArea(ProyectoSeleccionado.ARE_ID)
                            </span>
                        </div>
                    </div>

                    <div class="proyecto-separador"></div>

                    @* PROCESOS *@
                    <div class="info-section">
                        <label>PROCESOS REGISTRADOS</label>
                        <div class="proyecto-origen-card">
                            <i class="bi bi-diagram-3" style="color:#3b82f6;font-size:1rem;"></i>
                            <p class="info-value-small">@ObtenerCantidadProcesos(ProyectoSeleccionado.PRO_ID) proceso(s) asociados</p>
                        </div>
                    </div>

                    @* FECHAS *@
                    <div class="info-section">
                        <label>FECHAS</label>
                        <div class="fechas-card">
                            <div class="fecha-row">
                                <span class="fecha-icon-label"><i class="bi bi-play-circle" style="color:#16a34a;"></i> Inicio</span>
                                <span class="fecha-value">@ProyectoSeleccionado.PRO_FEC_INI.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="fecha-row">
                                <span class="fecha-icon-label"><i class="bi bi-stop-circle" style="color:#ef4444;"></i> Fin</span>
                                <span class="fecha-value">
                                    @(ProyectoSeleccionado.PRO_FEC_FIN.HasValue
                                                                    ? ProyectoSeleccionado.PRO_FEC_FIN.Value.ToString("dd/MM/yyyy")
                                                                    : "Sin fecha")
                            </span>
                        </div>
                    </div>
                </div>

                    @* DESCRIPCIÓN *@
                @if (!string.IsNullOrEmpty(ProyectoSeleccionado.PRO_DES))
                    {
                        <div class="info-section">
                            <label>DESCRIPCIÓN</label>
                            <div class="proyecto-desc-card">
                                <p class="info-value-small">@ProyectoSeleccionado.PRO_DES</p>
                            </div>
                        </div>
                    }

                    <div class="info-footer">
                        <i class="bi bi-calendar3"></i>
                        <span>Creado: @ProyectoSeleccionado.PRO_FEC_CRE.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-ES"))</span>
                    </div>
                </div>

                @* COLUMNA DERECHA: acciones e ilustración *@
                <div class="detalle-columna-acciones">
                    <div class="acciones-header">
                        <label>ACCIONES DISPONIBLES</label>
                    </div>

                    <div class="accion-card" @onclick="AbrirEditar">
                        <div class="accion-icon accion-icon-edit">
                            <i class="bi bi-pencil-fill"></i>
                        </div>
                        <div class="accion-texto">
                            <span class="accion-titulo">Editar Proyecto</span>
                            <span class="accion-desc">Modifica nombre, estado, fechas y descripción</span>
                        </div>
                        <i class="bi bi-chevron-right accion-arrow"></i>
                    </div>

                    <div class="accion-info-box">
                        <i class="bi bi-info-circle"></i>
                        <p>Si cambias el estado a uno distinto de <strong>FINALIZADO</strong>, el proyecto regresará automáticamente a la vista de proyectos activos.</p>
                    </div>
                </div>

            </div>

            <div class="modal-detalle-footer">
                <button class="btn-modal-cerrar" @onclick="CerrarDetalle">Cerrar</button>
                <button class="btn-modal-editar" @onclick="AbrirEditar">
                    <i class="bi bi-pencil-fill"></i> Editar Proyecto
                </button>
            </div>
        </div>
    </div>
}

@* ── MODAL EDITAR PROYECTO ── *@
@if (MostrarEditar && ProyectoSeleccionado != null)
{
    <div class="modal-overlay-editar">
        <EditarProyecto Proyecto="ProyectoSeleccionado" OnClose="CerrarEditar" />
    </div>
}
