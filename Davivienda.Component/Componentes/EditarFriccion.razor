@namespace Davivienda.Componentes
@using Davivienda.Models.Modelos
@using Davivienda.Component.Componentes
@using Microsoft.AspNetCore.Components

<div class="modal-premium-overlay" @onclick="Cerrar">
    <div class="modal-card-registro animate-pop" @onclick:stopPropagation>

        <div class="modal-top-accent-gold"></div>

        <div class="modal-header-registro">
            <h2 class="modal-title-main">Editar Fricción</h2>
            <button type="button" class="btn-close-x" @onclick="Cerrar">×</button>
        </div>

        <div class="modal-body-registro">
            <div class="form-grid-registro">

                @* Campo Tipo de Fricción *@
                <div class="input-group-registro full-width">
                    <label>TIPO DE FRICCIÓN</label>
                    <input type="text" @bind="fricEdit.FRI_TIP" class="input-field-premium" placeholder="Ej: Error de servidor, Retraso en aprobación" />
                </div>

                @* 🔥 Editor Yoopta para la Descripción Detallada *@
                <div class="input-group-registro full-width">
                    <label>DESCRIPCIÓN DEL BLOQUEO</label>
                    <div class="yoopta-editor-limiter">
                        <Yoopta Contenido="@fricEdit.FRI_DES"
                                ContenidoChanged="@((valor) => { fricEdit.FRI_DES = valor; })" />
                    </div>
                </div>

                @* Fila Doble: Estado e Impacto *@
                <div class="input-group-registro">
                    <label>ESTADO ACTUAL</label>
                    <select @bind="fricEdit.FRI_EST" class="input-field-premium select-premium">
                        <option value="Abierta">Abierta</option>
                        <option value="En Análisis">En Análisis</option>
                        <option value="Mitigada">Mitigada</option>
                        <option value="Resuelta">Resuelta</option>
                    </select>
                </div>

                <div class="input-group-registro">
                    <label>NIVEL DE IMPACTO</label>
                    <select @bind="fricEdit.FRI_IMP" class="input-field-premium select-premium">
                        <option value="Bajo">Bajo</option>
                        <option value="Medio">Medio</option>
                        <option value="Alto">Alto</option>
                        <option value="Crítico">Crítico</option>
                    </select>
                </div>
            </div>

            <div class="modal-footer-registro">
                <button type="button" class="btn-cancel-premium" @onclick="Cerrar">Cancelar</button>
                <button type="button" class="btn-save-premium" @onclick="ActualizarFriccion">Actualizar Registro</button>
            </div>
        </div>
    </div>
</div>