@namespace Davivienda.Component.Componentes
@using Davivienda.Models.Modelos
@using Microsoft.AspNetCore.Components

<div class="modal-premium-overlay" @onclick="Cerrar">
    <div class="modal-card-registro animate-pop" @onclick:stopPropagation>

        <div class="modal-top-accent-blue"></div>

        <div class="modal-header-registro">
            <h2 class="modal-title-main">Editar Solución</h2>
            <button type="button" class="btn-close-x" @onclick="Cerrar">×</button>
        </div>

        <div class="modal-body-registro">
            <div class="form-grid-registro">

                @* Campo Nombre *@
                <div class="input-group-registro full-width">
                    <label>NOMBRE DE LA SOLUCIÓN</label>
                    <input type="text" @bind="solEdit.SOL_NOM" class="input-field-premium" placeholder="Ej: Ajuste de índices en BD" />
                </div>

                @* 🔥 DESCRIPCIÓN TÉCNICA CON YOOPTA *@
                <div class="input-group-registro full-width">
                    <label>DESCRIPCIÓN TÉCNICA</label>
                    <div class="yoopta-editor-limiter">
                        <Yoopta Contenido="@solEdit.SOL_DES"
                                ContenidoChanged="@((valor) => { solEdit.SOL_DES = valor; })" />
                    </div>
                </div>

                @* Fila Doble: Estado y Efectividad *@
                <div class="input-group-registro">
                    <label>ESTADO ACTUAL</label>
                    <select @bind="solEdit.SOL_EST" class="input-field-premium select-premium">
                        <option value="Pendiente">Pendiente</option>
                        <option value="En Progreso">En Progreso</option>
                        <option value="Completada">Completada</option>
                    </select>
                </div>

                @* 🔥 NIVEL DE EFECTIVIDAD COMO SELECT DE NIVELES *@
                <div class="input-group-registro">
                    <label>NIVEL DE EFECTIVIDAD</label>
                    <select @bind="solEdit.SOL_NIV_EFE" class="input-field-premium select-premium">
                        <option value="100">Alto (100%)</option>
                        <option value="50">Medio (50%)</option>
                        <option value="25">Bajo (25%)</option>
                    </select>
                </div>
            </div>

            <div class="modal-footer-registro">
                <button type="button" class="btn-cancel-premium" @onclick="Cerrar">Cancelar</button>
                <button type="button" class="btn-save-premium" @onclick="ActualizarSolucion">Actualizar Registro</button>
            </div>
        </div>
    </div>
</div>