@namespace Davivienda.Component.Componentes
@inherits Microsoft.AspNetCore.Components.ComponentBase
@using Davivienda.Models.Modelos

<div class="modal-fixed-backdrop">
    <div class="master-modal-container" @onclick:stopPropagation>
        <div class="dav-modal-art-bg">
            <button type="button" class="btn-close-modal" @onclick="Regresar">
                <i class="bi bi-x-lg"></i>
            </button>

            <div class="bg-blob blob-red-top"></div>
            <div class="bg-blob blob-red-bottom"></div>

            <div class="content-sectors-container">

                @* LISTADO *@
                <div class="sector-white-card sector-listado">
                    <div class="sector-label">Historial de Obstáculos</div>
                    <div class="sector-banner-header">
                        <div class="banner-waves"></div>
                        <div class="banner-content">
                            <div class="banner-icon">
                                <i class="bi bi-exclamation-triangle"></i> Gestión de Fricciones Activa
                            </div>
                            <div class="banner-charts-mockup">
                                <div class="mock-pie"></div>
                                <div class="mock-bars"><span></span><span></span><span></span></div>
                            </div>
                        </div>
                    </div>

                    <div class="solution-main-viewport">
                        @if (FriccionesFiltradas != null && FriccionesFiltradas.Any())
                        {
                            @foreach (var fri in FriccionesFiltradas)
                            {
                                <div class="solution-item-card" @onclick="() => AbrirDetalleFriccion(fri)">
                                    <div style="width: 6px; height: 40px; border-radius: 3px; background: @ObtenerColorTarea(fri.TAR_ID); margin-right: -5px;"></div>
                                    <div class="sol-card-info">
                                        <span class="sol-name">@fri.FRI_TIP</span>
                                    </div>
                                    <div class="sol-card-metrics">
                                        <div class="metric-badge status">
                                            <i class="bi bi-shield-exclamation"></i> @fri.FRI_IMP
                                        </div>
                                        <div class="metric-badge effectiveness">
                                            <i class="bi bi-activity"></i> @fri.FRI_EST
                                        </div>
                                    </div>
                                    <div class="sol-arrow-action"><i class="bi bi-chevron-right"></i></div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-results-msg">
                                <i class="bi bi-wind"></i>
                                <p>Sin resultados.</p>
                            </div>
                        }
                    </div>
                </div>

                @* FILTROS *@
                <div class="sector-white-card sector-filtros">
                    <div class="sector-label">Filtros Inteligentes</div>
                    <div class="dynamic-filter-zone">
                        <Filtros Areas="AreasList"
                                 Proyectos="ProyectosList"
                                 Procesos="ProcesosGlobales"
                                 Tareas="TareasGlobales"
                                 Prioridades="PrioridadesList"
                                 OnFiltrosChanged="ManejarCambioFiltros" />
                    </div>
                </div>

            </div>

            <div class="illustration-scene">
                <div class="device-monitor">
                    <div class="device-screen"><div class="screen-ui-lines"></div></div>
                </div>
                <div class="vector-person person-standing"></div>
                <div class="vector-person person-climbing"></div>
                <div class="vector-person person-sitting"></div>
                <div class="floating-element element-1"></div>
                <div class="floating-element element-2"></div>
            </div>
        </div>
    </div>
</div>

@* ── MODAL DETALLE FRICCIÓN — diseño mejorado ── *@
@if (FriccionSeleccionada != null)
{
    <div class="modal-detalle-overlay" @onclick="CerrarDetalle">
        <div class="modal-detalle-card" @onclick:stopPropagation>

            @* HEADER *@
            <div class="modal-detalle-header">
                <div class="header-icon">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <h3 class="modal-detalle-title">Análisis de Fricción</h3>
                <button class="btn-cerrar-detalle" @onclick="CerrarDetalle">×</button>
            </div>

            @* BODY *@
            <div class="modal-detalle-body">

                @* COLUMNA IZQUIERDA — rediseñada *@
                <div class="detalle-columna-info">

                    @* NOMBRE — grande y destacado *@
                    <div class="friccion-nombre-hero">
                        <div class="friccion-nombre-icon">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                        </div>
                        <div class="friccion-nombre-texto">
                            <span class="friccion-nombre-label">TIPO DE OBSTÁCULO</span>
                            <h2 class="friccion-nombre-titulo">@FriccionSeleccionada.FRI_TIP</h2>
                        </div>
                    </div>

                    @* BADGES impacto y estado *@
                    <div class="friccion-badges-row">
                        <div class="friccion-badge-item">
                            <span class="friccion-badge-label">IMPACTO</span>
                            <span class="badge-impacto">
                                <i class="bi bi-shield-exclamation"></i>
                                @FriccionSeleccionada.FRI_IMP
                            </span>
                        </div>
                        <div class="friccion-badge-item">
                            <span class="friccion-badge-label">ESTADO</span>
                            <span class="badge-estado @ObtenerClaseEstado(FriccionSeleccionada.FRI_EST)">
                                <i class="bi bi-activity"></i>
                                @FriccionSeleccionada.FRI_EST
                            </span>
                        </div>
                    </div>

                    @* SEPARADOR *@
                    <div class="friccion-separador"></div>

                    @* TAREA ORIGEN *@
                    <div class="info-section">
                        <label>TAREA ORIGEN</label>
                        <div class="tarea-origen-card">
                            <div class="tarea-origen-dot" style="background: @ObtenerColorTarea(FriccionSeleccionada.TAR_ID);"></div>
                            <p class="info-value-small">@ObtenerNombreTarea(FriccionSeleccionada.TAR_ID)</p>
                        </div>
                    </div>

                    @* FECHA *@
                    <div class="info-footer">
                        <i class="bi bi-calendar3"></i>
                        <span>Registrado: @FriccionSeleccionada.FRI_FEC_CRE.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-ES"))</span>
                    </div>
                </div>

                @* COLUMNA DERECHA: YOOPTA *@
                <div class="detalle-columna-yoopta">
                    <div class="yoopta-header-modal">
                        <label>DESCRIPCIÓN DEL PROBLEMA</label>
                    </div>
                    <div class="yoopta-content-modal">
                        <Yoopta Contenido="@FriccionSeleccionada.FRI_DES"
                                ContenidoChanged="@((valor) => { })" />
                    </div>
                </div>

            </div>

            @* FOOTER *@
            <div class="modal-detalle-footer">
                <button class="btn-modal-cerrar" @onclick="CerrarDetalle">Cerrar</button>
                @* Solo Gerente y Lider Tecnico *@
                @if (PuedeVerTarea)
                {
                    <button class="btn-modal-ver-tarea" @onclick="VerTareaPadre">
                        <i class="bi bi-eye"></i> Ver Tarea Padre
                    </button>
                }
            </div>
        </div>
    </div>
}

@* ── DETALLE TAREA — mismo patrón que Asignaciones ── *@
@if (TareaParaDetalle != null)
{
    <div class="modal-backdrop-dav" @onclick="CerrarDetalleTarea">
        <div class="modal-calendar-content" @onclick:stopPropagation>
            <div class="modal-header-dav">
                <h3 style="font-weight:800;color:#1e3a5f;margin:0;">Detalle de Tarea</h3>
                <button class="close-btn-dav" @onclick="CerrarDetalleTarea">x</button>
            </div>
            <div class="modal-body-dav">
                <DetalleTarea Tarea="TareaParaDetalle" OnClose="CerrarDetalleTarea" />
            </div>
        </div>
    </div>
}
