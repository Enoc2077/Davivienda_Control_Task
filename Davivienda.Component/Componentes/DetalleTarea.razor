@namespace Davivienda.Component.Componentes
@using Davivienda.Models.Modelos
@using Davivienda.GraphQL.SDK
@implements IAsyncDisposable

<div class="modal-fullscreen-overlay">

    @* ── TOOLBAR SUPERIOR ── *@
    <div class="toolbar-dav-top">
        <div class="toolbar-content-full">

            @* Izquierda: marca + selector bitacoras *@
            <div class="toolbar-left-group">
                <div class="toolbar-brand">
                    <div class="toolbar-brand-dot"></div>
                    <span class="toolbar-brand-name">Gestión de Tareas</span>
                </div>
                <div class="toolbar-divider"></div>
                <div class="selector-container-premium">
                    <span class="selector-label">Ver Bitácora:</span>
                    <select class="select-dav-mini" @onchange="ManejarCambioBitacora">
                        <option value="">-- Seleccionar --</option>
                        <option value="BIT_SOL">Bitácora de Soluciones</option>
                        <option value="BIT_FRI">Bitácora de Fricciones</option>
                    </select>
                </div>
            </div>

            @* Derecha: boton cerrar *@
            <button type="button" class="btn-close-fullscreen" @onclick="Cerrar" title="Cerrar">
                <i class="bi bi-x"></i>
            </button>
        </div>
    </div>

    @* ── GRID 2x2 ── *@
    <div class="modal-content-container">

        @* ── TOP-LEFT: Información de Ejecución (sin cuadro, fondo blanco) ── *@
        <div class="sector-detalles">
            <div class="sector-header">
                <div class="title-group">
                    <h3 class="sector-title">Información de Ejecución</h3>
                    <span class="sector-subtitle">Detalles de la tarea</span>
                </div>
            </div>

            @if (Tarea != null)
            {
                <div class="detalles-list">
                    <div class="detail-row">
                        <span class="detail-label">Título de la tarea</span>
                        <p class="detail-value">@Tarea.TAR_NOM</p>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Proyecto asociado</span>
                        <p class="detail-value highlight-blue">@NombreProyecto</p>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Proceso actual</span>
                        <p class="detail-value">@NombreProceso</p>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Fecha de inicio</span>
                        <p class="detail-value highlight-green">@Tarea.TAR_FEC_INI.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Fecha de finalización</span>
                        <p class="detail-value highlight-red">
                            @if (Tarea.TAR_FEC_FIN.HasValue)
                            {
                                @Tarea.TAR_FEC_FIN.Value.ToString("dd/MM/yyyy HH:mm")
                            }
                            else
                            {
                                <span class="text-muted">Sin fecha estimada</span>
                            }
                        </p>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Estado actual</span>
                        <select @bind="Tarea.TAR_EST" class="select-status-compact">
                            <option value="Pendiente">Pendiente</option>
                            <option value="En Progreso">En Progreso</option>
                            <option value="Completado">Completado</option>
                        </select>
                    </div>
                </div>
            }
        </div>

        @* ── TOP-RIGHT: Descripción / Yoopta (sin cuadro, fondo blanco) ── *@
        <div class="sector-notas">
            <div class="sector-header-with-button">
                <div class="title-group">
                    <h3 class="sector-title">Descripción</h3>
                    <span class="sector-subtitle">Notas y documentos</span>
                </div>
            </div>

            @* Borde gris sutil alrededor del editor (punto 7) *@
            <div class="descripcion-wrapper">
                <span class="descripcion-label">Descripción</span>
                @if (Tarea != null)
                {
                    <Yoopta Contenido="@Tarea.TAR_DES"
                            ContenidoChanged="@((valor) => { Tarea.TAR_DES = valor; })" />
                }
            </div>
        </div>

        @* ── BOTTOM-LEFT: Soluciones ── *@
        <div class="sector-soluciones">
            <div class="sector-bottom-header">
                <div class="title-group">
                    <h3 class="sector-title">Soluciones</h3>
                    <span class="sector-subtitle">Propuestas activas</span>
                </div>
                <button type="button" class="btn-add-text" @onclick="AbrirModalCrearSolucion">
                    <i class="bi bi-plus-lg"></i> Nueva
                </button>
            </div>

            <div class="sector-bottom-list">
                @if (SolucionesList?.Any() == true)
                {
                    @foreach (var sol in SolucionesList)
                    {
                        <div class="item-card-mini" @onclick="() => AbrirModalEditarSolucion(sol)">
                            <div class="item-card-left">
                                <div class="item-card-icon icon-sol">
                                    <i class="bi bi-lightbulb"></i>
                                </div>
                                <span class="item-card-name">@sol.SOL_NOM</span>
                            </div>
                            <button type="button" class="btn-del"
                                    title="Eliminar solución"
                                    @onclick:stopPropagation
                                    @onclick="() => EliminarSolucion(sol.SOL_ID)">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </div>
                    }
                }
                else
                {
                    <p class="empty-message">No hay soluciones registradas</p>
                }
            </div>
        </div>

        @* ── BOTTOM-RIGHT: Fricciones ── *@
        <div class="sector-fricciones">
            <div class="sector-bottom-header">
                <div class="title-group">
                    <h3 class="sector-title">Fricciones</h3>
                    <span class="sector-subtitle">Obstáculos detectados</span>
                </div>
                <button type="button" class="btn-add-text" @onclick="AbrirModalCrearFriccion">
                    <i class="bi bi-plus-lg"></i> Nueva
                </button>
            </div>

            <div class="sector-bottom-list">
                @if (FriccionesList?.Any() == true)
                {
                    @foreach (var fri in FriccionesList)
                    {
                        <div class="item-card-mini" @onclick="() => AbrirModalEditarFriccion(fri)">
                            <div class="item-card-left">
                                <div class="item-card-icon icon-fri">
                                    <i class="bi bi-exclamation-triangle"></i>
                                </div>
                                <span class="item-card-name">@fri.FRI_TIP</span>
                            </div>
                            <button type="button" class="btn-del"
                                    title="Eliminar fricción"
                                    @onclick:stopPropagation
                                    @onclick="() => EliminarFriccion(fri.FRI_ID)">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </div>
                    }
                }
                else
                {
                    <p class="empty-message">No hay fricciones reportadas</p>
                }
            </div>
        </div>

    </div>

    @* ── MODALES INTERNOS ── *@
    @if (MostrarModalCrear)
    {
        <div class="modal-backdrop-premium" @onclick="CerrarModalInterno">
            <div class="modal-window-dav" @onclick:stopPropagation>
                <div class="modal-header-dav">
                    <h3>@TituloModal</h3>
                    <button type="button" class="modal-close-x" @onclick="CerrarModalInterno">
                        <i class="bi bi-x"></i>
                    </button>
                </div>
                <div class="modal-body-dav">
                    @if (TipoModal == "FRICCION_NUEVA" && Tarea != null)
                    {
                        <CrearFriccion TareaId="@Tarea.TAR_ID" OnSuccess="AlCrearExitoso" OnClose="CerrarModalInterno" />
                    }
                    else if (TipoModal == "SOLUCION_NUEVA")
                    {
                        <CrearSolucion FriccionId="@(FriccionesList?.FirstOrDefault()?.FRI_ID ?? Guid.Empty)"
                                       TareaId="@(Tarea?.TAR_ID ?? Guid.Empty)"
                                       OnSuccess="AlCrearExitoso"
                                       OnClose="CerrarModalInterno" />
                    }
                    else if (TipoModal == "SOLUCION_EDITAR" && SolucionSeleccionada != null)
                    {
                        <EditarSolucion Solucion="@SolucionSeleccionada"
                                        FriccionesDisponibles="@FriccionesList"
                                        OnSuccess="AlCrearExitoso"
                                        OnClose="CerrarModalInterno" />
                    }
                    else if (TipoModal == "FRICCION_EDITAR" && FriccionSeleccionada != null)
                    {
                        <Davivienda.Componentes.EditarFriccion Friccion="@FriccionSeleccionada" OnSuccess="AlCrearExitoso" OnClose="CerrarModalInterno" />
                    }
                    else if (TipoModal == "HISTORIAL_SOLUCIONES")
                    {
                        <BitacoraSolucion OnClose="CerrarModalInterno" />
                    }
                    else if (TipoModal == "HISTORIAL_FRICCIONES")
                    {
                        <BitacoraFriccion OnClose="CerrarModalInterno" />
                    }
                </div>
            </div>
        </div>
    }

</div>
