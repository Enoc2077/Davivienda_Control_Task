@namespace Davivienda.Component.Componentes
@using Davivienda.Models.Modelos
@using Davivienda.GraphQL.SDK
@using Microsoft.AspNetCore.Components

<div class="modal-premium-overlay" @onclick="CerrarModalInterno">
    <div class="modal-card-registro animate-pop" @onclick:stopPropagation>

        @* Franja superior degradado Davivienda *@
        <div class="modal-top-accent-gold"></div>

        @* Header *@
        <div class="modal-header-registro">
            <div class="modal-header-left">
                <div class="modal-header-icon sol-icon">
                    <i class="bi bi-lightbulb-fill"></i>
                </div>
                <div>
                    <h2 class="modal-title-main">Registrar Solución</h2>
                    <span class="modal-title-sub">Propuesta de resolución</span>
                </div>
            </div>
            <button type="button" class="btn-close-x" @onclick="CerrarModalInterno">
                <i class="bi bi-x"></i>
            </button>
        </div>

        @* Body *@
        <div class="modal-body-registro">
            <div class="form-grid-registro">

                @* Nombre de la Solución *@
                <div class="input-group-registro full-width">
                    <label>Nombre de la solución</label>
                    <input type="text"
                           @bind="nuevaSolucion.SOL_NOM"
                           class="input-field-premium"
                           placeholder="Ej: Automatización de carga de datos..." />
                </div>

                @* Descripción con Yoopta *@
                <div class="input-group-registro full-width">
                    <label>Descripción técnica</label>
                    <div class="yoopta-editor-container">
                        <Yoopta Contenido="@nuevaSolucion.SOL_DES"
                                ContenidoChanged="@((valor) => { nuevaSolucion.SOL_DES = valor; })" />
                    </div>
                </div>

                @* NUEVO punto 4: Friccion asociada *@
                <div class="input-group-registro full-width">
                    <label>Fricción asociada</label>
                    <select @bind="friccionSeleccionadaId" class="input-field-premium select-premium">
                        <option value="">-- Sin fricción asociada --</option>
                        @if (FriccionesDisponibles != null)
                        {
                            @foreach (var fri in FriccionesDisponibles)
                            {
                                <option value="@fri.FRI_ID">@fri.FRI_TIP</option>
                            }
                        }
                        @if (FriccionesDisponibles == null || !FriccionesDisponibles.Any())
                        {
                            <option value="" disabled>No hay fricciones registradas</option>
                        }
                    </select>
                </div>

                @* Estado y Efectividad *@
                <div class="input-group-registro">
                    <label>Estado actual</label>
                    <select @bind="nuevaSolucion.SOL_EST" class="input-field-premium select-premium">
                        <option value="Pendiente">Pendiente</option>
                        <option value="En Progreso">En Progreso</option>
                        <option value="Completada">Completada</option>
                    </select>
                </div>

                @* PUNTO 3: Nivel de efectividad con 4 opciones *@
                <div class="input-group-registro">
                    <label>Nivel de efectividad</label>
                    <select @bind="nuevaSolucion.SOL_NIV_EFE" class="input-field-premium select-premium">
                        <option value="25">Bajo (25%)</option>
                        <option value="50">Medio (50%)</option>
                        <option value="75">Alto (75%)</option>
                        <option value="100">Muy alto (100%)</option>
                    </select>
                </div>

            </div>

            @* Footer botones *@
            <div class="modal-footer-registro">
                <button type="button" class="btn-cancel-premium" @onclick="CerrarModalInterno">
                    <i class="bi bi-x-circle"></i> Cancelar
                </button>
                <button type="button" class="btn-save-premium" @onclick="GuardarSolucion">
                    <i class="bi bi-check-circle"></i> Guardar Registro
                </button>
            </div>
        </div>

    </div>
</div>
