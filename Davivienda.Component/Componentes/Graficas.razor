@using Microsoft.AspNetCore.Components

<div class="grafica-container-mejorada">
    <div class="grafica-barras-wrapper">
        @* Contenedor de Barras y Total a la derecha *@
        <div class="barras-con-total">
            @* Barras a la izquierda *@
            <div class="barras-modernas-container">
                @* BARRA 1: PENDIENTE (AZUL) *@
                <div class="barra-wrapper-moderna" @onclick='() => OnFiltrar.InvokeAsync("Pendiente")'>
                    <div class="barra-moderna">
                        <div class="barra-relleno pendiente-color"
                             style="height: @CalcularAltura(Pendientes)%">
                            <div class="barra-valor">@Pendientes</div>
                        </div>
                    </div>
                    <div class="barra-label">
                        <div class="label-dot pendiente-dot"></div>
                        <span>PENDIENTE</span>
                    </div>
                </div>

                @* BARRA 2: EN PROGRESO (AMARILLO/NARANJA) *@
                <div class="barra-wrapper-moderna" @onclick='() => OnFiltrar.InvokeAsync("En Progreso")'>
                    <div class="barra-moderna">
                        <div class="barra-relleno progreso-color"
                             style="height: @CalcularAltura(EnProgreso)%">
                            <div class="barra-valor">@EnProgreso</div>
                        </div>
                    </div>
                    <div class="barra-label">
                        <div class="label-dot progreso-dot"></div>
                        <span>EN PROGRESO</span>
                    </div>
                </div>

                @* BARRA 3: COMPLETADO (VERDE) *@
                <div class="barra-wrapper-moderna" @onclick='() => OnFiltrar.InvokeAsync("Completado")'>
                    <div class="barra-moderna">
                        <div class="barra-relleno completado-color"
                             style="height: @CalcularAltura(Completadas)%">
                            <div class="barra-valor">@Completadas</div>
                        </div>
                    </div>
                    <div class="barra-label">
                        <div class="label-dot completado-dot"></div>
                        <span>COMPLETADO</span>
                    </div>
                </div>
            </div>

            @* Total a la derecha *@
            <div class="total-count-lateral">
                <span class="numero-grande">@TotalTareas</span>
                <span class="texto-pequeno">Tareas Totales</span>
            </div>
        </div>

       
    </div>
</div>
