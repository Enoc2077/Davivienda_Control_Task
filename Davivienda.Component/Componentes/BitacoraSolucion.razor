@namespace Davivienda.Component.Componentes
@inherits Microsoft.AspNetCore.Components.ComponentBase
@using Davivienda.Models.Modelos

<div class="modal-fixed-backdrop">
    <div class="master-modal-container" @onclick:stopPropagation>
        <div class="dav-modal-art-bg">
            <button type="button" class="btn-close-modal" @onclick="Regresar"><i class="bi bi-x-lg"></i></button>

            <div class="bg-blob blob-red-top"></div>
            <div class="bg-blob blob-red-bottom"></div>

            <div class="content-sectors-container">
                @* LISTADO *@
                <div class="sector-white-card sector-large">
                    <div class="sector-label">Historial de Soluciones</div>
                    <div class="sector-banner-header">
                        <div class="banner-waves"></div>
                        <div class="banner-content">
                            <div class="banner-icon"><i class="bi bi-pencil-square"></i> Bitácora de Gestión</div>
                        </div>
                    </div>

                    <div class="solution-main-viewport custom-scroll">
                        @if (SolucionesFiltradas.Any())
                        {
                            @foreach (var sol in SolucionesFiltradas)
                            {
                                <div class="solution-item-card animate-pop" @onclick="() => SeleccionarSolucion(sol)">
                                    <div class="sol-card-info">
                                        <span class="sol-name">@sol.SOL_NOM</span>
                                        <p class="sol-desc-short">@sol.SOL_DES</p>
                                    </div>
                                    <div class="sol-card-metrics">
                                        <div class="metric-badge status">@sol.SOL_EST</div>
                                        <div class="metric-badge effectiveness">@sol.SOL_NIV_EFE%</div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-results-msg"><i class="bi bi-search"></i><p>Sin resultados.</p></div>
                        }
                    </div>
                </div>

                @* FILTROS DINÁMICOS *@
                <div class="sector-white-card sector-small">
                    <div class="sector-label">Filtros Inteligentes</div>
                    <div class="dynamic-filter-zone">
                        <Filtros Areas="AreasList" Proyectos="ProyectosList" Procesos="ProcesosList" Tareas="TareasList" Prioridades="PrioridadesList" OnFiltrosChanged="ManejarCambioFiltros" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (SolucionSeleccionada != null)
{
    <div class="modal-detail-overlay" @onclick="() => SolucionSeleccionada = null">
        <div @onclick:stopPropagation>
            <Davivienda.Component.Componentes.DetalleTarea Tarea="ConvertirASolucionModel(SolucionSeleccionada)" OnClose="() => SolucionSeleccionada = null" />
        </div>
    </div>
}